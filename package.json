{
  "name": "zesty-finance-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "db:migrate": "dotenvx run -f .env.local -- node ./dist/src/db/migrator.js",
    "db:migrate:create": "npm run db:migrate -- create",
    "db:migrate:down": "npm run db:migrate -- down",
    "db:migrate:up": "npm run db:migrate -- up",
    "db:migrate:latest": "npm run db:migrate -- latest",
    "build": "npm run build --workspace=zesty-finance-shared && rm -rf ./dist && tsc",
    "start:dev": "concurrently \"npm run dev --workspace=zesty-finance-shared\" \"tsc-watch --onSuccess 'dotenvx run -f .env.local -- node ./dist/index.js'\"",
    "start:prod": "npm run build && dotenvx run -f .env.production -- ts-node ./dist/index.mjs",
    "test": "mocha ./src/tests/**/*.spec.mjs",
    "test:watch": "npm run test --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "zesty-finance-shared": "*",
    "@dotenvx/dotenvx": "^1.52.0",
    "better-auth": "^1.5.5",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "express": "^4.22.1",
    "kysely": "^0.28.14",
    "lodash-es": "^4.17.23",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.3",
    "pg": "^8.18.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/winston": "^2.4.4",
    "chai": "^5.2.0",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "tsc-watch": "^6.2.1",
    "typescript": "^6.0.0"
  }
}
